<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            style="?attr/materialCardViewFilledStyle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DeviceAdmin PoC"
                    android:textAppearance="?attr/textAppearanceHeadlineMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Password Reset Vulnerability Research"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="12dp" />

                <!-- Status Chip Group -->
                <com.google.android.material.chip.ChipGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="false">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_admin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Admin: Inactive"
                        android:checkable="false"
                        style="?attr/chipAssistStyle" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_pin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PIN: Unverified"
                        android:checkable="false"
                        style="?attr/chipAssistStyle" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_question"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Security Q: Unverified"
                        android:checkable="false"
                        style="?attr/chipAssistStyle" />
                </com.google.android.material.chip.ChipGroup>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 1: Enable Device Admin -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            style="?attr/materialCardViewFilledStyle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Step 1: Device Admin"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/enable_admin_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable Device Administrator"
                    app:icon="@android:drawable/ic_lock_idle_lock"
                    app:iconGravity="textStart"
                    style="?attr/filledButtonStyle" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 2: PIN Verification -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            style="?attr/materialCardViewFilledStyle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Step 2: PIN Verification"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter PIN (minimum 4 digits)"
                    android:layout_marginBottom="8dp"
                    style="?attr/textInputLayoutOutlinedBoxStyle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/pin_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberPassword"
                        android:maxLength="8" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/verify_pin_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Verify PIN"
                    app:icon="@android:drawable/ic_secure"
                    app:iconGravity="textStart"
                    style="?attr/tonalButtonStyle" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 3: Security Question -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            style="?attr/materialCardViewFilledStyle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Step 3: Security Question"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What is the name of your first pet?"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Your answer"
                    android:layout_marginBottom="8dp"
                    style="?attr/textInputLayoutOutlinedBoxStyle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/answer_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLength="50" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/verify_question_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Verify Answer"
                    app:icon="@android:drawable/ic_dialog_info"
                    app:iconGravity="textStart"
                    style="?attr/tonalButtonStyle" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 4: Password Reset -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            style="?attr/materialCardViewFilledStyle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Step 4: Reset Password"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Complete all verification steps above first"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="New Password (minimum 6 characters)"
                    android:layout_marginBottom="12dp"
                    app:passwordToggleEnabled="true"
                    style="?attr/textInputLayoutOutlinedBoxStyle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/new_password_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:maxLength="32" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/reset_password_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Reset Device Password"
                    android:textAllCaps="true"
                    app:icon="@android:drawable/ic_lock_lock"
                    app:iconGravity="textStart"
                    app:cornerRadius="12dp"
                    style="?attr/filledButtonStyle" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ For authorized security research only"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorError"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
