<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#1a1a2e">

    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textColor="#e94560"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:padding="16dp"
        android:background="#16213e"
        android:layout_marginBottom="16dp" />

    <!-- Step 1: Enable Device Admin -->
    <Button
        android:id="@+id/enable_admin_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. ENABLE DEVICE ADMIN"
        android:backgroundTint="#0f3460"
        android:textColor="#ffffff"
        android:layout_marginBottom="8dp" />

    <!-- Step 2: PIN Verification -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/pin_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Enter PIN (4+ digits)"
            android:inputType="numberPassword"
            android:textColor="#e94560"
            android:hintTextColor="#533483"
            android:backgroundTint="#0f3460" />

        <Button
            android:id="@+id/verify_pin_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VERIFY"
            android:backgroundTint="#533483"
            android:textColor="#ffffff"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Step 3: Security Question -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Security Question: What is your first pet's name?"
        android:textColor="#e94560"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/answer_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Answer"
            android:inputType="text"
            android:textColor="#e94560"
            android:hintTextColor="#533483"
            android:backgroundTint="#0f3460" />

        <Button
            android:id="@+id/verify_question_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VERIFY"
            android:backgroundTint="#533483"
            android:textColor="#ffffff"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Step 4: New Password -->
    <EditText
        android:id="@+id/new_password_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="New Password (6+ chars)"
        android:inputType="textPassword"
        android:textColor="#e94560"
        android:hintTextColor="#533483"
        android:backgroundTint="#0f3460"
        android:layout_marginBottom="16dp" />

    <!-- Reset Button -->
    <Button
        android:id="@+id/reset_password_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RESET DEVICE PASSWORD"
        android:backgroundTint="#e94560"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
